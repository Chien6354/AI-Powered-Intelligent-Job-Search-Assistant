# DeepSeek (OpenAI-compatible)
# 复制本文件为同目录下的 .env 并填写密钥；勿把真实 key 写进 .env.example 或提交到 git
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# OpenAI 嵌入（当 config/settings.yaml 中 embedding_backend=openai 时必填）
# 不要把真实 key 提交到 git；切勿在聊天里发送给他人
OPENAI_API_KEY=
# 可选：兼容 OpenAI 格式的第三方网关，默认留空使用官方 https://api.openai.com/v1
# OPENAI_BASE_URL=

# Optional: contact in User-Agent for crawlers
CRAWL_CONTACT_EMAIL=your@email.example

# Optional: Hugging Face（下载 bge-m3 等模型时提高限速，非必须）
# 在 https://huggingface.co/settings/tokens 创建 Read 令牌后填入：
# HF_TOKEN=hf_xxx

# Optional: 国内镜像（与代理二选一即可），例如：
# HF_ENDPOINT=https://hf-mirror.com

# Tavily 搜索（招聘意图无库命中时联网兜底；config/settings.yaml 中 web_search_enabled=true）
# 见 https://tavily.com — 不要把真实 key 提交到 git
# TAVILY_API_KEY=
